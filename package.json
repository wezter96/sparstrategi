{
  "name": "sparstrategi",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.22",
      "lucide-react": "^1.21.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.1",
      "effect": "4.0.0-beta.93",
      "@effect/platform-bun": "4.0.0-beta.93",
      "@effect/sql-sqlite-bun": "4.0.0-beta.93",
      "@effect/atom-react": "4.0.0-beta.93",
      "drizzle-orm": "1.0.0-rc.4",
      "recharts": "^3.3.1"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "effect-language-service patch",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev -F web",
    "dev:server": "turbo run dev -F server",
    "db:push": "turbo run db:push -F @sparstrategi/db",
    "db:studio": "turbo run db:studio -F @sparstrategi/db",
    "db:generate": "turbo run db:generate -F @sparstrategi/db",
    "db:migrate": "turbo run db:migrate -F @sparstrategi/db",
    "db:local": "turbo run db:local -F @sparstrategi/db"
  },
  "dependencies": {
    "@sparstrategi/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@sparstrategi/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.10.2",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11"
}
